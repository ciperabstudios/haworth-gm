{
  "name": "haworth",
  "version": "1.0.0",
  "private": true,
  "description": "Haworth gamemode made with @infernus/core.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev:clean": "rimraf dist/bundle.js",
    "dev:server": "powershell -ExecutionPolicy Bypass -File scripts/dev-server.ps1",
    "dev:watch": "cross-env NODE_ENV=development rslib build -w",
    "dev": "npm-run-all dev:clean -p dev:watch dev:server",
    "build": "cross-env NODE_ENV=production rslib build",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "preinstall": "pnpx only-allow pnpm -y",
    "dep-check": "pnpx knip",
    "circular-deps-check": "pnpx madge --circular --extensions ts ./src"
  },
  "dependencies": {
    "@infernus/core": "0.14.4",
    "@infernus/gps": "0.0.1",
    "@infernus/raknet": "0.12.0",
    "bcryptjs": "2.4.3",
    "dayjs": "1.11.10",
    "dotenv": "16.4.5",
    "moment": "2.30.1",
    "mongoose": "8.1.1",
    "node-fetch": "2.7.0",
    "uuid": "11.1.0",
    "winston": "3.17.0"
  },
  "devDependencies": {
    "@eslint/js": "9.34.0",
    "@infernus/types": "0.1.0",
    "@rslib/core": "0.0.18",
    "@types/bcryptjs": "2.4.6",
    "@types/node": "20.11.16",
    "cross-env": "7.0.3",
    "eslint": "9.34.0",
    "globals": "16.3.0",
    "npm-run-all": "4.1.5",
    "oxlint": "1.39.0",
    "rimraf": "6.1.2",
    "type-fest": "5.4.1",
    "typescript": "5.3.3",
    "typescript-eslint": "8.42.0"
  }
}